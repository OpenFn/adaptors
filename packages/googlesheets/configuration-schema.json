{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "access_token": {
      "title": "Access Token",
      "type": "string",
      "description": "OAuth2 access token for Google Sheets",
      "writeOnly": true,
      "minLength": 1,
      "examples": [
        "eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiIsIng1dCI6IjlGWERwYmZNRlQyU3ZRdVhoODQ2WVR3RUlCdyIsI"
      ]
    },
    "private_key": {
      "title": "Private Key",
      "type": "string",
      "description": "RSA private key from the Google service account JSON key file",
      "writeOnly": true,
      "minLength": 1,
      "examples": [
        "-----BEGIN RSA PRIVATE KEY-----\nMIIEow..."
      ]
    },
    "client_email": {
      "title": "Client Email",
      "type": "string",
      "description": "Service account email address (e.g. my-app@project-id.iam.gserviceaccount.com)",
      "minLength": 1,
      "examples": [
        "my-app@project-id.iam.gserviceaccount.com"
      ]
    }
  },
  "oneOf": [
    {
      "$comment": "OAuth2",
      "required": ["access_token"]
    },
    {
      "$comment": "Service Account",
      "required": ["private_key", "client_email"]
    }
  ],
  "additionalProperties": true
}
