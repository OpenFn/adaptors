{
  "name": "@openfn/language-image-utils",
  "version": "1.0.0",
  "description": "OpenFn image-utils adaptor",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./types/index.d.ts",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "pnpm clean && build-adaptor image-utils",
    "test": "mocha --experimental-specifier-resolution=node --no-warnings --timeout 30000",
    "test:watch": "mocha -w --experimental-specifier-resolution=node --no-warnings --timeout 30000",
    "test:integration": "mocha --experimental-specifier-resolution=node --no-warnings test/integration.js",
    "clean": "rimraf dist types docs",
    "pack": "pnpm pack --pack-destination ../../dist",
    "lint": "eslint src",
    "benchmark": "echo 'benchmark removed — jsquash dependency dropped'"
  },
  "author": "Open Function Group",
  "license": "LGPLv3",
  "files": [
    "dist/",
    "types/",
    "ast.json",
    "configuration-schema.json"
  ],
  "dependencies": {
    "@openfn/language-common": "workspace:*",
    "jimp": "^1.6.0",
    "piexifjs": "^1.0.6"
  },
  "devDependencies": {
    "assertion-error": "2.0.0",
    "chai": "4.3.6",
    "deep-eql": "4.1.1",
    "mocha": "^10.7.3",
    "rimraf": "3.0.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/openfn/adaptors.git"
  },
  "types": "types/index.d.ts",
  "main": "dist/index.cjs"
}
