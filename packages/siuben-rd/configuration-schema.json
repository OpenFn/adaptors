{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "baseUrl": {
      "title": "Base URL",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "description": "The SIUBEN base URL",
      "format": "uri",
      "minLength": 1,
      "examples": ["https://siuben-endpoint.com"]
    },
    "Username": {
      "title": "Username",
      "type": "string",
      "description": "Username",
      "examples": ["test"]
    },
    "Password": {
      "title": "Password",
      "type": "string",
      "description": "Password",
      "writeOnly": true,
      "examples": ["@some(!)Str0ngp4ss0w0rd"]
    }
  },
  "type": "object",
  "additionalProperties": true,
  "required": ["Password", "Username", "baseUrl"]
}
