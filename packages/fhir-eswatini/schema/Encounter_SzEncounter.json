          "type": "Extension",
          "desc": "Extensions that cannot be ignored even if unrecognized"
        },
        "class": {
          "type": "Coding",
          "desc": "inpatient | outpatient | ambulatory | emergency +",
          "valueSet": "http://terminology.hl7.org/ValueSet/v3-ActEncounterCode|3.0.0"
        },
        "period": {
          "type": "Period",
          "desc": "The time that the episode was in the specified class"
        }
      }
    },
    "type": {
      "type": [
        "CodeableConcept"
      ],
      "isArray": true,
