      "valueSet": "http://hl7.org/fhir/ValueSet/appointment-cancellation-reason|4.0.1"
    },
    "serviceCategory": {
      "type": [
        "CodeableConcept"
      ],
      "isArray": true,
      "desc": "A broad categorization of the service that is to be performed during this appointment",
