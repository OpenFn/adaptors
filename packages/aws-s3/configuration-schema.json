{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "accessKeyId": {
      "title": "AWS Access Key ID",
      "type": "string",
      "description": "AWS access key id",
      "examples": ["AKIA..."]
    },
    "secretAccessKey": {
      "title": "AWS Secret Access Key",
      "type": "string",
      "description": "AWS secret key",
      "writeOnly": true
    },
    "sessionToken": {
      "title": "AWS Session Token",
      "type": "string",
      "description": "Optional temporary session token (for STS).",
      "writeOnly": true
    },
    "region": {
      "title": "AWS Region",
      "type": "string",
      "description": "AWS region to use (e.g. us-east-1).",
      "examples": ["us-east-1"]
    },
    "endpoint": {
      "title": "Override endpoint",
      "type": "string",
      "description": "Optional S3 endpoint (useful for LocalStack or S3-compatible services).",
      "format": "uri"
    },
    "bucket": {
      "title": "Bucket",
      "type": "string",
      "description": "Optional bucket name to use"
    }
  },
  "type": "object",
  "additionalProperties": false
}
